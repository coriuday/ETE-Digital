# ============================================================
# ETE Digital / Jobsrow — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in ALL values marked REQUIRED.
# NEVER commit .env to git. Use this file as the reference only.
#
# Security checklist before going live:
#  [ ] Generate JWT_SECRET_KEY:   python -c "import secrets; print(secrets.token_hex(32))"
#  [ ] Generate ENCRYPTION_KEY:   python -c "import secrets; print(secrets.token_hex(32))"
#  [ ] Rotate Supabase DB password in the Supabase dashboard
#  [ ] Revoke and regenerate Google OAuth client secret
#  [ ] Revoke and regenerate Resend API key
#  [ ] Revoke and regenerate Gemini API key
# ============================================================

# Environment
ENVIRONMENT=development       # development | production
DEBUG=True                    # Set False in production

# ── Local Docker Compose (optional) ──────────────────────────
# When using `docker compose up` from ete-digital/, set these in ete-digital/.env:
#   POSTGRES_PASSWORD=changeme_in_env   # docker-compose.yml default for NEW volumes
#   If Postgres volume already exists, password is fixed at first init — do not change
#   without recreating the postgres_data volume.
#   JWT_SECRET_KEY=<32+ char secret>
#   ENCRYPTION_KEY=<32+ char secret>
#   MINIO_ACCESS_KEY=minioadmin
#   MINIO_SECRET_KEY=minioadmin123

# ── Database ─────────────────────────────────────────────────
# REQUIRED. Supabase PostgreSQL (Session Pooler, port 5432 for asyncpg)
# Format: postgresql://postgres.PROJECT_REF:[DB_PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:CHANGE_ME@host:5432/dbname

# ── Redis (optional) ─────────────────────────────────────────
# Falls back to in-memory rate limiting if not set
# REDIS_URL=redis://localhost:6379/0

# ── Security Keys ────────────────────────────────────────────
# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Changing JWT_SECRET_KEY invalidates all existing sessions.
# WARNING: Changing ENCRYPTION_KEY without migrating data breaks all encrypted vault data.
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
ENCRYPTION_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ── Google OAuth ─────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# 1. Create OAuth 2.0 Client ID (Web application type)
# 2. Add Authorized redirect URIs:
#    - Dev:  http://localhost:8000/api/auth/oauth/google/callback
#    - Prod: https://your-backend.onrender.com/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# ── Email — Resend ───────────────────────────────────────────
# Get from: resend.com → API Keys → Create Key
EMAIL_ENABLED=true
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
SMTP_FROM_EMAIL=noreply@yourdomain.com
# Resend SMTP fallback (same key as RESEND_API_KEY)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USE_TLS=false
SMTP_USER=resend
SMTP_PASSWORD=re_your_resend_api_key

# ── SMS / Phone (optional) ───────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# ── File Storage — MinIO ─────────────────────────────────────
# For local dev, use docker-compose to run MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=False

# ── Stripe — future implementation (uncomment when enabling payments/billing) ──
# STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── AI Matching — Google Gemini ──────────────────────────────
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn-optional
LOG_LEVEL=INFO

# ── Frontend URL ─────────────────────────────────────────────
# Used for OAuth callback redirects and email links
FRONTEND_URL=http://localhost:5173  # Dev
# FRONTEND_URL=https://jobsrow.com  # Production
