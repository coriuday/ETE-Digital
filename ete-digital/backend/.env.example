# Environment
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql://ete_user:ete_dev_password_change_in_prod@localhost:5432/ete_digital

# Redis
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ENCRYPTION_KEY=your-encryption-key-change-in-production-min-32-chars

# OAuth2 - Google (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 - LinkedIn (Get from LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Email (MailHog for development — visit http://localhost:8025 to see sent emails)
EMAIL_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@etedigital.com
# Set to true for Gmail/Mailgun/SendGrid (port 587)
SMTP_USE_TLS=false
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# Production example (Gmail):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=your-app-password

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=False

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Monitoring
SENTRY_DSN=your-sentry-dsn-optional
LOG_LEVEL=INFO
