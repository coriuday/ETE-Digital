# Environment
ENVIRONMENT=development
DEBUG=True

# Database (Supabase PostgreSQL recommended)
# Format: postgresql://postgres.PROJECT_REF:[DB_PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — optional; app falls back to in-memory rate limiting if not set
# REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ENCRYPTION_KEY=your-encryption-key-change-in-production-min-32-chars

# OAuth2 - Google (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email
EMAIL_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@etedigital.com
# Set to true for Gmail/Mailgun/SendGrid (port 587)
SMTP_USE_TLS=false
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# Production example (Gmail):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=False

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Monitoring
SENTRY_DSN=your-sentry-dsn-optional
LOG_LEVEL=INFO
