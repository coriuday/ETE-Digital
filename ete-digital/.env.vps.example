# ============================================================
# ETE Digital / Jobrows — VPS Environment Template
# ============================================================
# Copy this file to backend/.env and fill in ALL required values.
# NEVER commit backend/.env to git.
#
# Differences from .env.example:
#   - ENVIRONMENT=production, DEBUG=false
#   - DATABASE_URL points to the internal Postgres container
#   - REDIS_URL set (required for multi-worker rate limiting)
#   - MINIO credentials are rotated (no defaults)
#   - CADDY_DOMAIN, DEPLOY_MODE, WORKERS are VPS-specific
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── VPS Deployment Mode ──────────────────────────────────────
# 'vps'    → gunicorn multi-worker (recommended for VPS)
# 'render' → uvicorn single worker (for Render.com)
DEPLOY_MODE=vps
# Number of gunicorn workers (leave empty to auto-detect from CPU count)
WORKERS=

# ── Caddy (Reverse Proxy + TLS) ──────────────────────────────
# Your domain — Caddy will auto-obtain a TLS cert from Let's Encrypt
CADDY_DOMAIN=yourdomain.com

# ── Database (internal Docker network) ───────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
# When using docker-compose, the hostname is 'postgres' (the service name)
DATABASE_URL=postgresql+asyncpg://ete_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ete_digital

# Docker Postgres credentials (must match DATABASE_URL)
POSTGRES_DB=ete_digital
POSTGRES_USER=ete_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis (required in production for cross-worker rate limiting) ─
REDIS_URL=redis://redis:6379/0

# ── Security Keys ────────────────────────────────────────────
# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Changing JWT_SECRET_KEY invalidates all existing sessions.
# WARNING: Changing ENCRYPTION_KEY without migrating data corrupts vault data.
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
ENCRYPTION_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ── Frontend URL ─────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com

# ── CORS ─────────────────────────────────────────────────────
# Already set in config.py — override here if needed:
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── MinIO (Object Storage) ───────────────────────────────────
# REQUIRED: Change these — never use the defaults in production.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_minimum_8_chars
MINIO_SECURE=false
MINIO_BUCKET_NAME=ete-digital

# ── Email — Resend (recommended) ─────────────────────────────
EMAIL_ENABLED=true
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USE_TLS=false
SMTP_USER=resend
SMTP_PASSWORD=re_your_resend_api_key

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/oauth/google/callback

# ── Stripe (optional) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_live_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── AI Matching — Google Gemini (optional) ───────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Monitoring — Sentry (optional but recommended) ───────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Build args (for docker compose) ──────────────────────────
# Same domain as FRONTEND_URL — Caddy serves /api/* and SPA on one host.
VITE_API_URL=https://yourdomain.com

# ── Hostinger VPS notes ──────────────────────────────────────
# 1. Copy this file to backend/.env (setup-vps.sh does this automatically)
# 2. Also symlink or copy POSTGRES_PASSWORD + CADDY_DOMAIN vars so compose can read them:
#      cp backend/.env .env   (from ete-digital/ directory, for compose variable substitution)
# 3. Deploy: docker compose --profile vps up -d --build
# 4. Do NOT use infra/vps_deploy.sh (legacy PM2/nginx — hardcoded secrets)
# 5. Set WORKERS=1 until WebSocket Redis pub/sub is implemented (multi-worker breaks live notifications)
WORKERS=1

# ── Pre-deploy security checklist ────────────────────────────
# [ ] Generated JWT_SECRET_KEY with secrets.token_hex(32)
# [ ] Generated ENCRYPTION_KEY with secrets.token_hex(32)
# [ ] Set strong POSTGRES_PASSWORD (not reused)
# [ ] Rotated MINIO_ACCESS_KEY and MINIO_SECRET_KEY
# [ ] Set CADDY_DOMAIN to real domain
# [ ] DNS A record pointing to VPS IP
# [ ] Ports 80 and 443 open in VPS firewall
# [ ] docker compose --profile vps up -d
# [ ] curl https://yourdomain.com/health → {"status": "healthy"}
