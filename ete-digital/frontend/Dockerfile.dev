# ── Dev Dockerfile (HMR + volume mounts) ──────────────────────────────────────
# Used by docker-compose.override.yml for local development only.
# The production image is in Dockerfile.
FROM node:22-alpine AS development

WORKDIR /app

# Install deps (layer-cached; node_modules come from volume override in compose)
COPY package.json package-lock.json ./
RUN npm ci

# Source is mounted via docker-compose volume — no COPY needed
EXPOSE 5173

# --host exposes Vite's dev server to the Docker network (required for port mapping)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
